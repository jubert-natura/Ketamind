{
  "$schema": "https://schemas.tokens.studio/v1/tokens.schema.json",
  "$description": "ketaMIND — Botanical OS · Design Tokens · v7. W3C DTCG format. Desktop 1440 values.",
  "color": {
    "ink": {
      "primary": { "$value": "#151518", "$type": "color", "$description": "Primary ink — body and headings on light surfaces." },
      "soft":    { "$value": "#717182", "$type": "color", "$description": "Soft ink — secondary copy, captions." },
      "faint":   { "$value": "#B5B5BD", "$type": "color", "$description": "Faint ink — disabled/tertiary text." }
    },
    "paper": {
      "cream": { "$value": "#FFFCF8", "$type": "color", "$description": "Default page background — warm cream." },
      "white": { "$value": "#FFFFFF", "$type": "color", "$description": "Pure surface — cards, modals." },
      "warm":  { "$value": "#FAF6EF", "$type": "color", "$description": "Warm offset — section bands, ticket stubs." }
    },
    "holo": {
      "lilac":      { "$value": "#DFB2FF", "$type": "color" },
      "violet":     { "$value": "#AC9CFF", "$type": "color" },
      "periwinkle": { "$value": "#8CA4FC", "$type": "color" },
      "sky":        { "$value": "#7EC4FF", "$type": "color" },
      "cyan":       { "$value": "#8CE2EF", "$type": "color" },
      "mint":       { "$value": "#8BD4B6", "$type": "color" },
      "lime":       { "$value": "#7ED576", "$type": "color" }
    },
    "sky": {
      "lavender":   { "$value": "#F0E5FB", "$type": "color" },
      "periwinkle": { "$value": "#E5E8FC", "$type": "color" },
      "cyan":       { "$value": "#E0F4F9", "$type": "color" },
      "mint":       { "$value": "#E2F2EA", "$type": "color" },
      "lime":       { "$value": "#E8F4D6", "$type": "color" }
    },
    "accent": {
      "lime": { "$value": "#D4F25C", "$type": "color", "$description": "Highlight CTA accent." }
    },
    "border": {
      "hairline": { "$value": "#E5E5E9", "$type": "color" },
      "soft":     { "$value": "#ECECF0", "$type": "color" }
    }
  },
  "gradient": {
    "holoSpectrum": {
      "$type": "gradient",
      "$value": [
        { "color": "#DFB2FF", "position": 0 },
        { "color": "#AC9CFF", "position": 0.17 },
        { "color": "#8CA4FC", "position": 0.33 },
        { "color": "#7EC4FF", "position": 0.5 },
        { "color": "#8CE2EF", "position": 0.67 },
        { "color": "#8BD4B6", "position": 0.83 },
        { "color": "#7ED576", "position": 1 }
      ],
      "$description": "90° linear — the signature holo strip."
    },
    "holoDiagonal": {
      "$type": "gradient",
      "$value": [
        { "color": "#DFB2FF", "position": 0 },
        { "color": "#AC9CFF", "position": 0.17 },
        { "color": "#8CA4FC", "position": 0.33 },
        { "color": "#7EC4FF", "position": 0.5 },
        { "color": "#8CE2EF", "position": 0.67 },
        { "color": "#8BD4B6", "position": 0.83 },
        { "color": "#7ED576", "position": 1 }
      ],
      "$description": "135° linear."
    },
    "holoSoft": {
      "$type": "gradient",
      "$value": [
        { "color": "#F0E5FB", "position": 0 },
        { "color": "#E5E8FC", "position": 0.25 },
        { "color": "#DEEBFB", "position": 0.5 },
        { "color": "#D8F0F2", "position": 0.75 },
        { "color": "#E2F2EA", "position": 1 }
      ],
      "$description": "Hazy atmospheric panel — used on hero blocks."
    },
    "holoSoftVertical": {
      "$type": "gradient",
      "$value": [
        { "color": "#F5EDFC", "position": 0 },
        { "color": "#E5EAFC", "position": 0.5 },
        { "color": "#E2F2EA", "position": 1 }
      ]
    },
    "auraRadial": {
      "$type": "gradient",
      "$value": "radial-gradient(ellipse 80% 60% at 50% 50%, rgba(223,178,255,0.45) 0%, rgba(140,164,252,0.30) 35%, rgba(140,226,239,0.18) 60%, rgba(126,213,118,0) 85%)",
      "$description": "Soft halo bloom — placed behind hero text and product packshots."
    }
  },
  "shadow": {
    "xs":        { "$type": "shadow", "$value": "0 1px 2px rgba(10,10,10,0.04)" },
    "soft":      { "$type": "shadow", "$value": "0 8px 32px rgba(10,10,10,0.06)" },
    "float":     { "$type": "shadow", "$value": "0 24px 64px rgba(10,10,10,0.10)" },
    "halo":      { "$type": "shadow", "$value": "0 0 80px rgba(172,156,255,0.45)" },
    "ticket":    { "$type": "shadow", "$value": "0 12px 40px rgba(10,10,10,0.08), 0 2px 6px rgba(10,10,10,0.04)" }
  },
  "radius": {
    "xs":   { "$type": "dimension", "$value": "6px" },
    "sm":   { "$type": "dimension", "$value": "12px" },
    "md":   { "$type": "dimension", "$value": "20px" },
    "lg":   { "$type": "dimension", "$value": "28px" },
    "xl":   { "$type": "dimension", "$value": "40px" },
    "2xl":  { "$type": "dimension", "$value": "56px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "spacing": {
    "$description": "8pt grid — Desktop 1440.",
    "0":  { "$type": "dimension", "$value": "0px" },
    "1":  { "$type": "dimension", "$value": "4px" },
    "2":  { "$type": "dimension", "$value": "8px" },
    "3":  { "$type": "dimension", "$value": "12px" },
    "4":  { "$type": "dimension", "$value": "16px" },
    "5":  { "$type": "dimension", "$value": "20px" },
    "6":  { "$type": "dimension", "$value": "24px" },
    "8":  { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "16": { "$type": "dimension", "$value": "64px" },
    "20": { "$type": "dimension", "$value": "80px" },
    "24": { "$type": "dimension", "$value": "96px" },
    "30": { "$type": "dimension", "$value": "120px" }
  },
  "typography": {
    "family": {
      "display":     { "$type": "fontFamily", "$value": ["Geist", "Inter", "system-ui", "sans-serif"] },
      "body":        { "$type": "fontFamily", "$value": ["Inter", "system-ui", "-apple-system", "sans-serif"] },
      "mono":        { "$type": "fontFamily", "$value": ["JetBrains Mono", "monospace"] },
      "italicSerif": { "$type": "fontFamily", "$value": ["DM Serif Display", "serif"] }
    },
    "weight": {
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":     { "$type": "fontWeight", "$value": 700 },
      "extrabold":{ "$type": "fontWeight", "$value": 800 },
      "black":    { "$type": "fontWeight", "$value": 900 }
    },
    "size": {
      "displayXl":  { "$type": "dimension", "$value": "128px", "$description": "Hero — clamp(56px, 9vw, 128px)" },
      "h1":         { "$type": "dimension", "$value": "72px",  "$description": "clamp(48px, 6vw, 72px)" },
      "h2":         { "$type": "dimension", "$value": "56px",  "$description": "clamp(40px, 5vw, 56px)" },
      "h3":         { "$type": "dimension", "$value": "40px",  "$description": "clamp(28px, 3.5vw, 40px)" },
      "h4":         { "$type": "dimension", "$value": "24px" },
      "h5":         { "$type": "dimension", "$value": "18px" },
      "bodyLg":     { "$type": "dimension", "$value": "17px" },
      "body":       { "$type": "dimension", "$value": "15px" },
      "caption":    { "$type": "dimension", "$value": "11px" },
      "mono":       { "$type": "dimension", "$value": "11px" },
      "eyebrow":    { "$type": "dimension", "$value": "11px" }
    },
    "lineHeight": {
      "tight":   { "$type": "number", "$value": 0.95 },
      "snug":    { "$type": "number", "$value": 1.1 },
      "normal":  { "$type": "number", "$value": 1.5 },
      "relaxed": { "$type": "number", "$value": 1.55 },
      "loose":   { "$type": "number", "$value": 1.6 }
    },
    "letterSpacing": {
      "tightest": { "$type": "dimension", "$value": "-0.035em" },
      "tighter":  { "$type": "dimension", "$value": "-0.02em" },
      "tight":    { "$type": "dimension", "$value": "-0.01em" },
      "normal":   { "$type": "dimension", "$value": "0" },
      "wide":     { "$type": "dimension", "$value": "0.04em" },
      "wider":    { "$type": "dimension", "$value": "0.12em" },
      "widest":   { "$type": "dimension", "$value": "0.2em" }
    },
    "style": {
      "displayXl": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.family.display}",
          "fontWeight":    "{typography.weight.black}",
          "fontSize":      "{typography.size.displayXl}",
          "lineHeight":    "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.tightest}"
        }
      },
      "h1": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.family.display}",
          "fontWeight":    "{typography.weight.black}",
          "fontSize":      "{typography.size.h1}",
          "lineHeight":    "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.letterSpacing.tighter}"
        }
      },
      "h2": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.family.display}",
          "fontWeight":    "{typography.weight.black}",
          "fontSize":      "{typography.size.h2}",
          "lineHeight":    "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.letterSpacing.tighter}"
        }
      },
      "h3": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.family.display}",
          "fontWeight":    "{typography.weight.extrabold}",
          "fontSize":      "{typography.size.h3}",
          "lineHeight":    "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.letterSpacing.tighter}"
        }
      },
      "h4": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.family.body}",
          "fontWeight":    "{typography.weight.bold}",
          "fontSize":      "{typography.size.h4}",
          "lineHeight":    "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "eyebrow": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.family.body}",
          "fontWeight":    "{typography.weight.medium}",
          "fontSize":      "{typography.size.eyebrow}",
          "lineHeight":    "{typography.lineHeight.normal}",
          "letterSpacing": "{typography.letterSpacing.widest}",
          "textCase":      "uppercase"
        }
      },
      "bodyLg": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.family.body}",
          "fontWeight":    "{typography.weight.regular}",
          "fontSize":      "{typography.size.bodyLg}",
          "lineHeight":    "{typography.lineHeight.relaxed}"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.family.body}",
          "fontWeight":    "{typography.weight.regular}",
          "fontSize":      "{typography.size.body}",
          "lineHeight":    "{typography.lineHeight.normal}"
        }
      },
      "mono": {
        "$type": "typography",
        "$value": {
          "fontFamily":    "{typography.family.mono}",
          "fontSize":      "{typography.size.mono}",
          "letterSpacing": "0.02em"
        }
      }
    }
  },
  "motion": {
    "duration": {
      "fast":   { "$type": "duration", "$value": "150ms" },
      "base":   { "$type": "duration", "$value": "250ms" },
      "slow":   { "$type": "duration", "$value": "350ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] }
    }
  }
}
